# Serverni nechanchi portda ishga tushirish
PORT=5987

# Frontend manzili (CORS uchun)
CLIENT_URL=http://localhost:5173

# Telegram MTProto API kalitlari — https://my.telegram.org dan oling:
#   1. Telefon raqamingiz bilan kiring
#   2. "API development tools" ni oching
#   3. App yarating va api_id / api_hash ni shu yerga qo'ying
TG_API_ID=
TG_API_HASH=

# Sessiya stringini imzolash uchun maxfiy kalit (uzun va tasodifiy bo'lsin)
JWT_SECRET=change_this_to_a_long_random_string
